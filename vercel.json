{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "devCommand": "bun run dev",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/paintings",
      "destination": "/gallery",
      "permanent": true
    },
    {
      "source": "/artworks",
      "destination": "/gallery",
      "permanent": true
    },
    {
      "source": "/murals",
      "destination": "/gallery",
      "permanent": true
    },
    {
      "source": "/portfolio",
      "destination": "/gallery",
      "permanent": true
    }
  ]
}
